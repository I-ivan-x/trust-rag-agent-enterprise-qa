# Mock mode is only for tests, CI, and smoke tests.
# Formal evaluation must use real embedding, real reranker, and real LLM providers.
APP_NAME=TrustRAG Enterprise QA
APP_VERSION=0.1.0
TASK_PLAN_VERSION=v0.3-q1-hard-demo-plan-freeze
ENVIRONMENT=dev
DEBUG=true
MOCK_MODE=true

DATA_DIR=data
GENERATED_DIR=data/generated
SAMPLE_CORPUS_DIR=data/sample_corpus
PUBLIC_CORPUS_DIR=data/public_corpus
HARD_NEGATIVE_CORPUS_DIR=data/hard_negative_corpus
GOLD_EVAL_DIR=data/gold_eval
TRACE_DIR=data/traces
EVAL_RUNS_DIR=data/eval_runs

EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu
RERANKER_PROVIDER=mock
RERANKER_MODEL_NAME=mock-reranker-v0
LLM_PROVIDER=mock
LLM_MODEL_NAME=mock-llm-v0

OPENAI_API_KEY=
OPENAI_BASE_URL=

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=trust_rag_enterprise_qa
WHOOSH_INDEX_DIR=data/indexes/whoosh

CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=80
MAX_CONTEXT_TOKENS=5000
MAX_REWRITE_ROUNDS=1

EVAL_MODE=mock
