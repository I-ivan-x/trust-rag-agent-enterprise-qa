# Mock mode is only for tests, CI, and smoke tests.
# Formal evaluation must use real embedding, real reranker, and real LLM providers.
APP_NAME=TrustRAG Enterprise QA
APP_VERSION=0.1.0
TASK_PLAN_VERSION=v0.3-q1-hard-demo-plan-freeze
ENVIRONMENT=dev
DEBUG=true
MOCK_MODE=true

DATA_DIR=data
GENERATED_DIR=data/generated
SAMPLE_CORPUS_DIR=data/sample_corpus
PUBLIC_CORPUS_DIR=data/public_corpus
HARD_NEGATIVE_CORPUS_DIR=data/hard_negative_corpus
GOLD_EVAL_DIR=data/gold_eval
TRACE_DIR=data/traces
EVAL_RUNS_DIR=data/eval_runs

EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu
RERANKER_PROVIDER=bge
RERANKER_MODEL_NAME=BAAI/bge-reranker-base

# LLM_PROVIDER=mock keeps tests/CI/smoke deterministic.
# For real headline runs use a real provider (e.g. deepseek via its base_url).
LLM_PROVIDER=mock
LLM_MODEL_NAME=mock-llm-v0
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_TOKENS=512
LLM_TEMPERATURE=0

# Agentic query rewrite provider. rule_based keeps offline behavior deterministic;
# set to deepseek (or another real provider) for real final_agentic runs.
REWRITE_LLM_PROVIDER=rule_based
REWRITE_LLM_MODEL_NAME=mock-llm-v0

# Provider API keys are read from the environment and never logged or committed.
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=trust_rag_enterprise_qa
WHOOSH_INDEX_DIR=data/indexes/whoosh

CHUNK_MAX_TOKENS=500
CHUNK_OVERLAP_TOKENS=80
MAX_CONTEXT_TOKENS=5000
MAX_REWRITE_ROUNDS=1

EVAL_MODE=mock
